{
  "compilerOptions": {
    // 1. Tell TypeScript to recognize Bun's global variables and modules
    "types": ["@types/bun"],
    
    // 2. Allow modern modules and meta properties like import.meta.main
    "module": "ESNext",
    "target": "ESNext",
    "moduleResolution": "Bundler",
    
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"]
}